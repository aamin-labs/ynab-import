# YNAB Transaction Importer — Configuration Template
# Copy to .env and fill in your values
# Get account UUIDs from: https://app.ynab.com/settings -> API

# YNAB credentials (can also go in ~/.ynab.env)
YNAB_ACCESS_TOKEN=your-access-token-here
YNAB_BUDGET_ID=your-budget-id-here

# Map last digits of card/account number to YNAB account UUID
# For credit cards: use last 4 digits of card number
# For bank accounts: use last 2+ digits of account number
YNAB_ACCOUNT_2887=your-ynab-account-uuid-here
YNAB_ACCOUNT_3389=your-ynab-account-uuid-here
YNAB_ACCOUNT_2567=your-ynab-account-uuid-here
YNAB_ACCOUNT_02=your-ynab-account-uuid-here
YNAB_ACCOUNT_01=your-ynab-account-uuid-here
